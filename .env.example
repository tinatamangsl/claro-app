# Claro — Environment Variables
# Copy this file to .env and fill in your API keys
# Get your hackathon promo codes from Luma / Discord

# ===========================================
# TELNYX — ClawTalk Voice Calls
# https://telnyx.com
# ===========================================
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_PHONE_NUMBER=+1234567890
TELNYX_CONNECTION_ID=your_telnyx_connection_id

# ===========================================
# RESEMBLE AI — Chatterbox TTS Voice
# https://app.resemble.ai
# ===========================================
RESEMBLE_API_KEY=your_resemble_api_key_here
RESEMBLE_VOICE_UUID=your_claro_voice_uuid
RESEMBLE_PROJECT_UUID=your_project_uuid

# ===========================================
# APP CONFIG
# ===========================================
APP_BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# ===========================================
# DEMO USER (Natasha — used for hackathon demo)
# ===========================================
DEMO_PHONE=+447700000000
DEMO_USER_NAME=Natasha
